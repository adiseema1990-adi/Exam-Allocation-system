rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Global Default Deny Gate
    match /{document=**} {
      allow read, write: if false;
    }

    // Reuseable Global Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper to check if signed in
    function isEmailVerified() {
      return isSignedIn();
    }

    // Restrict write actions to authorized academic office administrators
    // Admins can be verified by mapping their UID in a database config or simple token flags
    function isAdministrator() {
      return isSignedIn() && 
        request.auth.token != null && 
        'email' in request.auth.token && (
          request.auth.token.email == 'admin@smvcer.ac.in' ||
          request.auth.token.email == 'adiseema1990@gmail.com' ||
          request.auth.token.email.matches('.*@smvcer\\.ac\\.in$') ||
          request.auth.token.email.matches('.*@grecraichur\\.ac\\.in$') ||
          request.auth.token.email.matches('.*@mvecollegerichur\\.edu\\.in$') ||
          exists(/databases/$(database)/documents/admins/$(request.auth.uid))
        );
    }

    // isValidId String Guard for safety
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // 2. Schema and type guards for Exam allocations
    function isValidExamAllocation(data) {
      return (
        // Field keys strict checklist
        data.keys().hasAll(['facultyName', 'department', 'date', 'session']) &&
        
        // Boundaries and character size limits
        data.facultyName is string &&
        data.facultyName.size() > 2 &&
        data.facultyName.size() <= 100 &&
        
        data.department is string &&
        data.department in ['CSE', 'ECE', 'Mechanical', 'Civil', 'AIML', 'MBA', 'Mathematics', 'Physics', 'Chemistry', 'Humanities', 'Others'] &&
        
        data.date is string &&
        data.date.size() == 10 &&
        data.date.matches('^\\d{4}-\\d{2}-\\d{2}$') &&
        
        data.session is string &&
        data.session in ['Morning', 'Forenoon', 'Afternoon', 'Full Day']
      );
    }

    // Schema and type guards for registered faculties
    function isValidFaculty(data) {
      return (
        data.keys().hasAll(['name', 'department']) &&
        data.name is string &&
        data.name.size() > 2 &&
        data.name.size() <= 100 &&
        data.department is string &&
        data.department in ['CSE', 'ECE', 'Mechanical', 'Civil', 'AIML', 'MBA', 'Mathematics', 'Physics', 'Chemistry', 'Humanities', 'Others']
      );
    }

    // Collection Level Validations matching blueprint path
    match /exam_allocations/{allocationId} {
      
      // Let standard users / viewers read the timetables instantly
      allow read: if true;

      // Only administrators can perform write edits
      allow create: if (
        isAdministrator() &&
        isValidId(allocationId) &&
        isValidExamAllocation(request.resource.data) &&
        request.resource.data.createdAt == request.time
      );

      allow update: if (
        isAdministrator() &&
        isValidId(allocationId) &&
        isValidExamAllocation(request.resource.data) &&
        request.resource.data.createdAt == resource.data.createdAt // Immutability on createdAt
      );

      allow delete: if (
        isAdministrator() &&
        isValidId(allocationId)
      );
    }

    // Faculties Registry Path
    match /faculties/{facultyId} {
      allow read: if true;
      allow create: if (
        isAdministrator() &&
        isValidId(facultyId) &&
        isValidFaculty(request.resource.data)
      );
      allow update: if (
        isAdministrator() &&
        isValidId(facultyId) &&
        isValidFaculty(request.resource.data)
      );
      allow delete: if (
        isAdministrator() &&
        isValidId(facultyId)
      );
    }

    // Admins path
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false; // System generated collection
    }
  }
}
